# PATH: wissen/static/.htaccess
# Version: 2026-02-27 09:00 Europe/Berlin
# Purpose:
# - Ensure UTF-8 for /wissen to prevent mojibake.
# - Canonical redirects for redundant URL paths.
# - Canonical 301 redirect from legacy /faq/ URLs to new /info/ URLs (PR-4.3/4.2).
# - Keep legacy redirects (consulting/style-guide) aligned to /info/.

<IfModule mod_headers.c>
  Header set X-Wissen-Htaccess "active"
</IfModule>

AddDefaultCharset UTF-8

<IfModule mod_mime.c>
  AddCharset UTF-8 .html .htm .css .js .json .xml .txt .svg
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # IMPORTANT: Correct URL-base for per-dir rewrites in /wissen.
  # Prevents accidental filesystem-path redirects.
  RewriteBase /wissen/

  # --- Canonical redirects: FAQ -> INFO (handles with/without trailing slash) ---
  RewriteRule ^de/faq/?$ /wissen/de/info/ [R=301,L]
  RewriteRule ^de/faq/(.*)$ /wissen/de/info/$1 [R=301,L]
  RewriteRule ^en/faq/?$ /wissen/en/info/ [R=301,L]
  RewriteRule ^en/faq/(.*)$ /wissen/en/info/$1 [R=301,L]

  # --- Legacy redirects (kept) now pointing to /info/ ---
  RewriteRule ^en/consulting/?$ /wissen/en/info/consulting/ [R=301,L]
  RewriteRule ^en/consulting/(.*)$ /wissen/en/info/consulting/$1 [R=301,L]
  RewriteRule ^en/style-guide/?$ /wissen/en/info/style-guide/ [R=301,L]
  RewriteRule ^en/style-guide/(.*)$ /wissen/en/info/style-guide/$1 [R=301,L]

  # --- Canonicalize duplicate locale segments ---
  RewriteRule ^de/de/(.*)$ /wissen/de/$1 [R=301,L]
  RewriteRule ^en/en/(.*)$ /wissen/en/$1 [R=301,L]

  # --- Canonicalize duplicate product segments (if any legacy URLs exist) ---
  RewriteRule ^de/produkte/produkte/?$ /wissen/de/produkte/ [R=301,L]
  RewriteRule ^de/produkte/produkte/(.*)$ /wissen/de/produkte/$1 [R=301,L]
  RewriteRule ^en/products/products/?$ /wissen/en/products/ [R=301,L]
  RewriteRule ^en/products/products/(.*)$ /wissen/en/products/$1 [R=301,L]

  # --- Legacy knowledge redirects (kept) ---
  RewriteRule ^de/oeffentlich/produkte/?$ /wissen/de/produkte/ [R=301,L]
  RewriteRule ^de/oeffentlich/produkte/(.*)$ /wissen/de/produkte/$1 [R=301,L]
  RewriteRule ^de/produktinfo/public/(.*)$ /wissen/de/produkte/$1 [R=301,L]
  RewriteRule ^de/produktinfo/?$ /wissen/de/produkte/ [R=301,L]
  RewriteRule ^de/produktinfo/(.*)$ /wissen/de/produkte/$1 [R=301,L]

  RewriteRule ^en/public/products/?$ /wissen/en/products/ [R=301,L]
  RewriteRule ^en/public/products/(.*)$ /wissen/en/products/$1 [R=301,L]

  # --- Do not rewrite existing files/dirs (after redirects above) ---
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
</IfModule>
